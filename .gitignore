# --- Core repository content to KEEP tracked ---
# Python source, shell scripts, package/config directories, and docs:
#   *.py, *.sh, README*.md, QUICKSTART.md, bota_driver_config/, bota_sensor/, stage_control/, etc.
# Calibration/config files that define behavior should remain tracked (for example: calibration.json).

# --- Python cache / local environment (DO NOT TRACK) ---
__pycache__/
**/__pycache__/
*.py[cod]
*.pyd
.Python
.venv/
venv/
env/

# --- Raw/derived experiment datasets (DO NOT TRACK) ---
experiment_data/
experiment_data_*/
experiment_plot_*/
experiment_plot_*.zip
experiment_plots/

# --- Local measurement exports and intermediate calibration data (DO NOT TRACK) ---
force*.csv

# --- Generated figures/reports (DO NOT TRACK) ---
calibration_fit*.png
calibration_fit*.svg

# --- Generic editor/OS noise (DO NOT TRACK) ---
.DS_Store
Thumbs.db
.vscode/
